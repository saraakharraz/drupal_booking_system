/**
 * Implements hook_theme().
 */
function appointment_theme($existing, $type, $theme, $path) {
  return [
    'appointment' => [
      'render element' => 'elements',
      'template' => 'appointment',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_preprocess_appointment().
 */
function appointment_preprocess_appointment(&$variables) {
  $variables['#attached']['library'][] = 'appointment/appointment.theme';

  $appointment = $variables['elements']['#appointment'];

  $variables['customer_name'] = $appointment->getCustomerName();
  $variables['customer_email'] = $appointment->getCustomerEmail();
  $variables['customer_phone'] = $appointment->getCustomerPhone();
  $variables['appointment_date'] = $appointment->getAppointmentDate();
  $variables['status'] = $appointment->getStatus();
  $variables['notes'] = $appointment->getNotes();

  $agency = $appointment->get('agency')->entity;
  $variables['agency'] = $agency ? $agency->getName() : t('Not specified');

  $adviser = $appointment->get('adviser')->entity;
  $variables['adviser'] = $adviser ? $adviser->getDisplayName() : t('Not assigned');

  $type = $appointment->get('appointment_type')->entity;
  $variables['appointment_type'] = $type ? $type->getName() : t('Not specified');
}
