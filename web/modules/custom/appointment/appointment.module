<?php

/**
 * @file
 * Appointment module hooks and functions.
 */

/**
 * Implements hook_entity_presave().
 *
 * Generate default title if empty: {ID}-{DATE}-{TIME}
 *
 */
function appointment_entity_presave(\Drupal\Core\Entity\EntityInterface $entity) {

  if ($entity->getEntityTypeId() !== 'appointment') {
    return;
  }

  $title = $entity->get('title')->value;
  $appointment_date = $entity->get('appointment_date')->value;

  // GENERATE DEFAULT TITLE IF EMPTY
  // Only generate if title is empty
  if (empty($title) && !empty($appointment_date)) {
    // Parse the date
    $datetime = new \DateTime($appointment_date);
    $date_str = $datetime->format('Y-m-d');
    $time_str = $datetime->format('H:i');

    // Generate title: {ID}-{DATE}-{TIME}
    // Use temporary ID for new appointments (will be updated in hook_entity_insert)
    $id = $entity->id() ?? 'NEW';
    $title = $id . '-' . $date_str . '-' . $time_str;

    $entity->set('title', $title);
  }
}

/**
 * Implements hook_entity_insert().
 *
 * Add RDV- prefix to all appointment titles (after insert).
 */
function appointment_entity_insert(\Drupal\Core\Entity\EntityInterface $entity) {
  // Only process appointment entities
  if ($entity->getEntityTypeId() !== 'appointment') {
    return;
  }

  $title = $entity->get('title')->value;

  // Update title with real ID if it was auto-generated with "NEW"
  if (strpos($title, 'NEW-') === 0 && !empty($entity->id())) {
    $appointment_date = $entity->get('appointment_date')->value;

    if (!empty($appointment_date)) {
      $datetime = new \DateTime($appointment_date);
      $date_str = $datetime->format('Y-m-d');
      $time_str = $datetime->format('H:i');

      // New title with real ID (before prefix)
      $title = $entity->id() . '-' . $date_str . '-' . $time_str;
    }
  }

  // Add RDV- prefix to ALL titles (only if not already present)
  if (!empty($title) && strpos($title, 'RDV-') !== 0) {
    $title = 'RDV-' . $title;

    // Update in database
    \Drupal::database()->update('appointment')
      ->fields(['title' => $title])
      ->condition('id', $entity->id())
      ->execute();

    // Update the entity object too
    $entity->set('title', $title);
  }
}


use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_update().
 */
function appointment_entity_update(EntityInterface $entity) {

  if ($entity->getEntityTypeId() !== 'appointment') {
    return;
  }

  // ------------------- 1. RDV- prefix -------------------
  $title = $entity->get('title')->value ?? '';
  if (!empty($title) && strpos($title, 'RDV-') !== 0) {
    $title = 'RDV-' . $title;

    \Drupal::database()->update('appointment')
      ->fields(['title' => $title])
      ->condition('id', $entity->id())
      ->execute();

    $entity->set('title', $title);
  }

  // ------------------- 2. Status change -------------------
  if (!$entity->original) {
    return;
  }

  $old_status = $entity->original->get('status')->value ?? '';
  $new_status = $entity->get('status')->value ?? '';

  \Drupal::logger('appointment')->notice('Old: @old → New: @new', [
    '@old' => $old_status,
    '@new' => $new_status,
  ]);

  // ------------------- 3. Send email if confirmed -------------------
  if ($old_status === 'pending' && $new_status === 'confirmed') {

    $mailManager = \Drupal::service('plugin.manager.mail');

    $params = [
      'customer_name'   => $entity->hasField('customer_name') ? $entity->get('customer_name')->value : '',
      'customer_email'  => $entity->hasField('customer_email') ? $entity->get('customer_email')->value : '',
      'customer_phone'  => $entity->hasField('customer_phone') ? $entity->get('customer_phone')->value : '',
      'customer_address'=> $entity->hasField('customer_address') ? $entity->get('customer_address')->value : '',
      'appointment_date'=> $entity->hasField('appointment_date') ? $entity->get('appointment_date')->value : '',
      'agency'          => $entity->hasField('agency') ? $entity->get('agency')->target_id : 0,
      'adviser'         => $entity->hasField('adviser') ? $entity->get('adviser')->target_id : 0,
      'type'            => $entity->hasField('appointment_type') ? $entity->get('appointment_type')->target_id : 0,
    ];

    $mailManager->mail(
      'appointment',
      'appointment_confirmation',
      $params['customer_email'],
      \Drupal::currentUser()->getPreferredLangcode(),
      $params
    );

    \Drupal::logger('appointment')->notice('Confirmation email triggered for: @email', [
      '@email' => $params['customer_email']
    ]);
  }
}


