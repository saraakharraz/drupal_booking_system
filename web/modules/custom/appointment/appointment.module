/**
 * Implements hook_mail().
 */
function appointment_mail($key, &$message, $params)
{
  switch ($key) {
    case 'access_link':
      $message['subject'] = t('Your appointments link');
      $message['body'][] = t("Hello,\n\nYou can view your appointments by clicking the link below:");
      $message['body'][] = $params['link'];
      $message['body'][] = t("\nThis link is valid for 24 hours.");
      break;
    case 'appointment_pending':
      $message['subject'] = t('Appointment Request Received');

      $body = "Hello {$params['customer_name']},\n\n";
      $body .= "Your appointment request has been received and is pending confirmation.\n\n";
      $body .= "We will notify you once it is confirmed.\n\n";
      $body .= "Thank you.";

      $message['body'][] = $body;
      break;
    // -----------------------------------------
    // Confirmation email
    // -----------------------------------------
    case 'appointment_confirmation':
      $message['subject'] = t('Appointment Confirmation');

      if (empty($params['appointment_date']) || empty($params['customer_name'])) {
        \Drupal::logger('appointment')->error('Missing email parameters for confirmation.');
        return;
      }

      try {
        $appt_date = new \DateTime($params['appointment_date']);
        $date_formatted = $appt_date->format('l d F Y');
        $time_start = $appt_date->format('H:i');
        $time_end = $appt_date->modify('+30 minutes')->format('H:i');
      } catch (\Exception $e) {
        \Drupal::logger('appointment')->error('Error parsing appointment date for confirmation: @error', [
          '@error' => $e->getMessage(),
        ]);
        return;
      }

      $agency = \Drupal::entityTypeManager()->getStorage('agency')->load($params['agency']);
      $adviser = \Drupal::entityTypeManager()->getStorage('user')->load($params['adviser']);
      $type = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($params['type']);

      $body = "Hello {$params['customer_name']},\n\n";
      $body .= "Your appointment has been confirmed!\n\n";
      $body .= "Date: $date_formatted\n";
      $body .= "Time: $time_start - $time_end\n";
      $body .= "Agency: " . ($agency ? $agency->getName() : 'Not specified') . "\n";
      $body .= "Adviser: " . ($adviser ? $adviser->getDisplayName() : 'Not assigned') . "\n";
      $body .= "Type: " . ($type ? $type->getName() : 'General') . "\n";
      $body .= "Phone: {$params['customer_phone']}\n";
      $body .= "Address: " . ($params['customer_address'] ?? 'Not specified') . "\n\n";
      $body .= "This is an automated email. Please do not reply.\n";

      $message['body'][] = $body;
      \Drupal::logger('appointment')->info('Confirmation email prepared for: @email', ['@email' => $params['customer_email']]);
      break;

    // -----------------------------------------
    // Modification email
    // -----------------------------------------
    case 'appointment_modification':
      $message['subject'] = t('Appointment Updated');

      if (empty($params['appointment_date']) || empty($params['customer_name'])) {
        \Drupal::logger('appointment')->error('Missing email parameters for modification.');
        return;
      }

      try {
        $appt_date = new \DateTime($params['appointment_date']);
        $date_formatted = $appt_date->format('l d F Y');
        $time_start = $appt_date->format('H:i');
        $time_end = $appt_date->modify('+30 minutes')->format('H:i');
      } catch (\Exception $e) {
        \Drupal::logger('appointment')->error('Error parsing appointment date for modification: @error', [
          '@error' => $e->getMessage(),
        ]);
        return;
      }

      $agency = \Drupal::entityTypeManager()->getStorage('agency')->load($params['agency']);
      $adviser = \Drupal::entityTypeManager()->getStorage('user')->load($params['adviser']);
      $type = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($params['type']);

      $body = "Hello {$params['customer_name']},\n\n";
      $body .= "Your appointment has been updated!\n\n";
      $body .= "Date: $date_formatted\n";
      $body .= "Time: $time_start - $time_end\n";
      $body .= "Agency: " . ($agency ? $agency->getName() : 'Not specified') . "\n";
      $body .= "Adviser: " . ($adviser ? $adviser->getDisplayName() : 'Not assigned') . "\n";
      $body .= "Type: " . ($type ? $type->getName() : 'General') . "\n";
      $body .= "Phone: {$params['customer_phone']}\n";
      $body .= "Address: " . ($params['customer_address'] ?? 'Not specified') . "\n\n";
      $body .= "This is an automated email. Please do not reply.\n";

      $message['body'][] = $body;
      \Drupal::logger('appointment')->info('Modification email prepared for: @email', ['@email' => $params['customer_email']]);
      break;

    // -----------------------------------------
    // Cancellation email
    // -----------------------------------------
    case 'appointment_cancellation':
      $message['subject'] = t('Appointment Cancelled');

      if (empty($params['appointment_date']) || empty($params['customer_name'])) {
        \Drupal::logger('appointment')->error('Missing email parameters for cancellation.');
        return;
      }

      try {
        $appt_date = new \DateTime($params['appointment_date']);
        $date_formatted = $appt_date->format('l d F Y');
        $time_start = $appt_date->format('H:i');
        $time_end = $appt_date->modify('+30 minutes')->format('H:i');
      } catch (\Exception $e) {
        \Drupal::logger('appointment')->error('Error parsing appointment date for cancellation: @error', [
          '@error' => $e->getMessage(),
        ]);
        return;
      }

      $agency = \Drupal::entityTypeManager()->getStorage('agency')->load($params['agency']);
      $adviser = \Drupal::entityTypeManager()->getStorage('user')->load($params['adviser']);
      $type = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($params['type']);

      $body = "Hello {$params['customer_name']},\n\n";
      $body .= "Your appointment has been cancelled.\n\n";
      $body .= "Date: $date_formatted\n";
      $body .= "Time: $time_start - $time_end\n";
      $body .= "Agency: " . ($agency ? $agency->getName() : 'Not specified') . "\n";
      $body .= "Adviser: " . ($adviser ? $adviser->getDisplayName() : 'Not assigned') . "\n";
      $body .= "Type: " . ($type ? $type->getName() : 'General') . "\n";
      $body .= "Phone: {$params['customer_phone']}\n";
      $body .= "Address: " . ($params['customer_address'] ?? 'Not specified') . "\n\n";
      $body .= "This is an automated email. Please do not reply.\n";

      $message['body'][] = $body;
      \Drupal::logger('appointment')->info('Cancellation email prepared for: @email', ['@email' => $params['customer_email']]);
      break;
  }

}




