<div class="appointment-view">
  <div class="appointment-header">
    <h2>{{ 'Appointment Details'|t }}</h2>
    <span class="appointment-status status--{{ status }}">{{ status|capitalize }}</span>
  </div>

  <div class="appointment-fields">
    <div class="field">
      <label>{{ 'Customer Name'|t }}</label>
      <span>{{ customer_name }}</span>
    </div>

    <div class="field">
      <label>{{ 'Email'|t }}</label>
      <span>{{ customer_email }}</span>
    </div>

    <div class="field">
      <label>{{ 'Phone'|t }}</label>
      <span>{{ customer_phone }}</span>
    </div>

    <div class="field">
      <label>{{ 'Appointment Date'|t }}</label>
      <span>{{ appointment_date }}</span>
    </div>

    <div class="field">
      <label>{{ 'Agency'|t }}</label>
      <span>{{ agency }}</span>
    </div>

    <div class="field">
      <label>{{ 'Adviser'|t }}</label>
      <span>{{ adviser }}</span>
    </div>

    <div class="field">
      <label>{{ 'Appointment Type'|t }}</label>
      <span>{{ appointment_type }}</span>
    </div>

    {% if notes %}
      <div class="field">
        <label>{{ 'Notes'|t }}</label>
        <span>{{ notes }}</span>
      </div>
    {% endif %}
  </div>
</div>
